---
import Base from '../layouts/Base.astro';
import { members } from '../data/members.js';

const activeCount = members.filter(m => m.status === 'ACTIVE').length;
const totalCount = members.length;
---
<Base title="FTS // ROSTER" page="members">

<style>
  .roster-header {
    padding: 4rem 2rem 3rem;
    max-width: 1400px;
    margin: 0 auto;
    border-bottom: 1px solid var(--border);
  }

  .roster-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 3px;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .roster-meta span { color: var(--hazard); }

  .roster-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(4rem, 14vw, 11rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .roster-stats {
    display: flex;
    gap: 3rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    font-family: var(--font-mono);
  }

  .stat-label {
    font-size: 0.7rem;
    letter-spacing: 3px;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .stat-value {
    font-family: var(--font-heavy);
    font-size: 2.5rem;
    color: var(--hazard);
    line-height: 1;
  }

  /* =========== DOSSIER CARDS =========== */
  .dossier-grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 2rem;
  }

  .dossier {
    background: var(--bg-2);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    transition: all 0.2s ease-out;
  }

  .dossier:hover {
    border-color: var(--hazard);
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0 var(--hazard);
  }

  .dossier-header {
    background: var(--ink);
    color: var(--bg);
    padding: 0.75rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 700;
  }

  .dossier-id::before {
    content: '#';
    color: var(--ink-muted);
    margin-right: 4px;
  }

  .status-active {
    color: var(--hazard-dark);
  }
  .status-active::before {
    content: '● ';
    color: var(--hazard-dark);
  }

  .status-inactive {
    color: var(--blood);
  }
  .status-inactive::before {
    content: '○ ';
  }

  .dossier-body {
    padding: 2rem 1.5rem;
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .skin-frame {
    width: 96px;
    height: 96px;
    background: var(--bg);
    border: 2px solid var(--hazard);
    padding: 8px;
    position: relative;
  }

  .skin-frame::after {
    content: '';
    position: absolute;
    inset: -2px;
    border: 1px solid var(--hazard);
    transform: translate(5px, 5px);
    opacity: 0.3;
    pointer-events: none;
  }

  .skin-head {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    display: block;
  }

  .dossier-info {
    min-width: 0;
  }

  .username {
    font-family: var(--font-heavy);
    font-size: 1.5rem;
    letter-spacing: 1px;
    word-break: break-word;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .username::before {
    content: '/ ';
    color: var(--hazard);
  }

  .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    background: var(--hazard);
    color: var(--bg);
    padding: 0.25rem 0.6rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .quote {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink);
    line-height: 1.6;
    padding-top: 1rem;
    border-top: 1px dashed var(--border);
    position: relative;
  }

  .quote::before {
    content: '"';
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--hazard);
    position: absolute;
    top: -0.5rem;
    left: -0.25rem;
    opacity: 0.3;
    line-height: 1;
  }

  .dossier-footer {
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 2px;
    color: var(--ink-muted);
    text-transform: uppercase;
    display: flex;
    justify-content: space-between;
  }

  /* corner cuts for industrial feel */
  .dossier::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 16px;
    height: 16px;
    background: var(--bg);
    clip-path: polygon(100% 0, 0 0, 100% 100%);
    z-index: 2;
  }

  /* empty state */
  .empty {
    grid-column: 1 / -1;
    padding: 4rem 2rem;
    text-align: center;
    border: 2px dashed var(--border);
    font-family: var(--font-mono);
    color: var(--ink-muted);
  }

  @media (max-width: 700px) {
    .roster-header { padding: 2rem 1rem; }
    .dossier-grid { padding: 2rem 1rem; gap: 1.5rem; }
    .dossier-body {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
      padding: 1.5rem 1rem;
    }
    .skin-frame { width: 80px; height: 80px; }
    .roster-stats { gap: 1.5rem; }
  }
</style>

<section class="roster-header">
  <div class="roster-meta">
    CLASSIFIED // <span>EYES ONLY</span> // PERSONNEL FILE
  </div>
  <h1 class="roster-title">The Roster</h1>
  <div class="roster-stats">
    <div class="stat">
      <div class="stat-label">Total Operatives</div>
      <div class="stat-value">{String(totalCount).padStart(3, '0')}</div>
    </div>
    <div class="stat">
      <div class="stat-label">Active Status</div>
      <div class="stat-value">{String(activeCount).padStart(3, '0')}</div>
    </div>
    <div class="stat">
      <div class="stat-label">Year Established</div>
      <div class="stat-value">2026</div>
    </div>
  </div>
</section>

<section class="dossier-grid">
  {members.length === 0 && (
    <div class="empty">NO OPERATIVES ON FILE</div>
  )}
  {members.map(m => (
    <article class="dossier">
      <header class="dossier-header">
        <span class="dossier-id">{m.id}</span>
        <span class={m.status === 'ACTIVE' ? 'status-active' : 'status-inactive'}>
          {m.status}
        </span>
      </header>

      <div class="dossier-body">
        <div class="skin-frame">
          <img
            src={`https://api.mineatar.io/face/${m.username}?scale=16`}
            alt={`${m.username}'s head`}
            class="skin-head"
            onerror="this.src='https://api.mineatar.io/face/MHF_Steve?scale=16'"
            loading="lazy"
          />
        </div>
        <div class="dossier-info">
          <h2 class="username">{m.username}</h2>
          <span class="tag">{m.tag}</span>
          <p class="quote">{m.quote}</p>
        </div>
      </div>

      <footer class="dossier-footer">
        <span>FTS / {m.id}</span>
        <span>VERIFIED ✓</span>
      </footer>
    </article>
  ))}
</section>

</Base>
